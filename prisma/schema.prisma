generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Team {
  id                  String               @id @default(uuid())
  name                String               @unique
  email               String?              @unique
  password            String?
  isAdmin             Boolean              @default(false)
  totalScore          Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
  playSessions        PlaySession[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  teamId    String
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Case {
  id                  String        @id @default(uuid())
  lang                String        @default("it")
  title               String
  story               String
  hint                String?
  correctLocation     String
  explanationLocation String        @default("-")
  locationChoices     String        @default("[]")
  correctSuspect      String
  explanationSuspect  String        @default("-")
  suspectChoices      String        @default("[]")
  correctWeapon       String
  explanationWeapon   String        @default("-")
  weaponChoices       String        @default("[]")
  createdAt           DateTime      @default(now())
  playSessions        PlaySession[]
}

model PlaySession {
  id                String   @id @default(uuid())
  teamId            String
  caseId            String?
  caseTitle         String?
  locationAnswer    String?
  suspectAnswer     String?
  weaponAnswer      String?
  isCorrectLocation Boolean  @default(false)
  isCorrectSuspect  Boolean  @default(false)
  isCorrectWeapon   Boolean  @default(false)
  scoreAwarded      Int      @default(0)
  completedAt       DateTime @default(now())
  caseItem          Case?    @relation(fields: [caseId], references: [id])
  team              Team     @relation(fields: [teamId], references: [id])
}
